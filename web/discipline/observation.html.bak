<!DOCTYPE html>
<html lang="zh-CN" data-theme="light">
<head>
  <meta charset="UTF-8">
  <link rel="icon" href="../images/favicon.svg" type="image/svg+xml">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>观察池 · 知行</title>
  <link rel="stylesheet" href="../shared/css/theme.css">
  <link rel="stylesheet" href="../shared/css/base.css">
  <link rel="stylesheet" href="../shared/css/xhs-cards.css">
  <link rel="stylesheet" href="../shared/css/components.css">
  <script src="../shared/js/theme.js"></script>
  <style>
    body { max-width: 1200px; margin: 0 auto; }
    .panel-header { padding: 16px 0 8px; }
    .panel-header h1 { font-family: var(--font-display); font-size: 1.2rem; font-weight: 900; margin: 0; }
    .panel-header p { font-size: 0.65rem; color: var(--text-tertiary); margin: 2px 0 0; }
    .obs-table { width: 100%; border-collapse: collapse; font-size: 0.7rem; }
    .obs-table th { text-align: center; padding: 8px 6px; border-bottom: 2px solid var(--divider); font-size: 0.6rem; font-weight: 700; color: var(--text-secondary); position: sticky; top: 0; background: var(--bg); cursor: pointer; user-select: none; white-space: nowrap; }
    .obs-table th:hover { color: var(--accent); }
    .obs-table th .sort-arrow { font-size: 0.5rem; margin-left: 2px; }
    .obs-table td { padding: 8px 6px; border-bottom: 1px solid var(--divider); text-align: center; }
    .obs-table tr:hover { background: var(--card-bg); }
    .obs-table a { color: var(--accent); text-decoration: none; font-weight: 600; }
    .tag { display: inline-block; padding: 1px 6px; border-radius: 6px; font-size: 0.55rem; font-weight: 600; }
    .tag-leader { background: #F3E5F5; color: #7B1FA2; }       /* 龙头 - 紫色 */
    .tag-burst { background: #E0F7FA; color: #00838F; }         /* 加速 - 青色 */
    .tag-double { background: #FFEBEE; color: #C62828; }        /* 双强 - 红色 */
    .tag-short { background: #E3F2FD; color: #1565C0; }         /* 短爆 - 蓝色 */
    .tag-steady { background: #E8F5E9; color: #2E7D32; }        /* 稳健 - 绿色 */
    .toolbar { display: flex; gap: 10px; align-items: center; flex-wrap: wrap; margin: 10px 0; }
    .toolbar input { padding: 5px 10px; border: 1px solid var(--divider); border-radius: 8px; font-size: 0.7rem; background: var(--card-bg); color: var(--text-primary); }
    .loading { text-align: center; padding: 40px; color: var(--text-tertiary); }
  </style>
</head>
<body>
  <div class="app-container">
    <nav class="top-nav" id="top-nav"></nav>

    <div class="panel-header">
      <h1>🔍 观察池</h1>
      <p id="date-label">加载中...</p>
    </div>

    <div class="toolbar">
      <input type="text" id="filter-input" placeholder="搜索股票代码或名称..." oninput="renderTable()">
      <select id="cat-filter" onchange="renderTable()" style="padding:5px 10px;border:1px solid var(--divider);border-radius:8px;font-size:0.7rem;background:var(--card-bg);color:var(--text-primary);">
        <option value="">全部类别</option>
        <option value="龙头">龙头</option>
        <option value="加速">加速</option>
        <option value="短爆">短爆</option>
        <option value="稳健">稳健</option>
      </select>
      <input type="date" id="date-input" onchange="loadByDate(this.value)" style="padding:5px 10px;border:1px solid var(--divider);border-radius:8px;font-size:0.7rem;background:var(--card-bg);color:var(--text-primary);">
    </div>

    <div id="table-wrap">
      <div class="loading">加载中...</div>
    </div>
  </div>

  <script src="../shared/js/nav.js"></script>
  <script>
    Nav.init({ brandIcon: '🦊', brandText: '知行', currentPage: 'discipline' });

    let allItems = [];
    let sortCol = 'composite_score';
    let sortDir = 'desc';

    function sortArrow(col) {
      if (col !== sortCol) return '';
      return sortDir === 'asc' ? ' ▲' : ' ▼';
    }

    function thClick(col) {
      if (sortCol === col) { sortDir = sortDir === 'asc' ? 'desc' : 'asc'; }
      else { sortCol = col; sortDir = 'desc'; }
      renderTable();
    }

    function formatSignals(item) {
      // V2: 优先 signals_json，回退 buy/sell 兼容
      if (item.signals_json) {
        try {
          const signals = JSON.parse(item.signals_json);
          if (signals && signals.length) {
            return `<span style="color:var(--accent);font-weight:600">${signals.length}个信号</span>`;
          }
        } catch (e) {}
      }
      // 兼容旧格式
      let count = 0;
      if (item.buy_signals_json) {
        try { const arr = JSON.parse(item.buy_signals_json); count += (arr || []).length; } catch(e) {}
      }
      if (item.sell_signals_json) {
        try { const arr = JSON.parse(item.sell_signals_json); count += (arr || []).length; } catch(e) {}
      }
      if (count > 0) return `<span style="color:var(--accent);font-weight:600">${count}个信号</span>`;
      return '<span style="color:var(--text-tertiary)">-</span>';
    }

    async function loadByDate(date) {
      try {
        let url = '/api/discipline/observation';
        if (date) url += '?date=' + date;
        const resp = await fetch(url);
        const data = await resp.json();
        allItems = data.items || [];
        document.getElementById('date-label').textContent = '数据日期: ' + (data.date || '--');
        if (data.date) document.getElementById('date-input').value = data.date;
        renderTable();
      } catch (e) {
        document.getElementById('table-wrap').innerHTML = '<div class="loading">加载失败: ' + e.message + '</div>';
      }
    }

    async function load() {
      // 默认加载最新日期（不传date参数）
      await loadByDate('');
    }

    function renderTable() {
      const filter = (document.getElementById('filter-input').value || '').toLowerCase();
      const cat = document.getElementById('cat-filter').value;

      let items = allItems.slice();
      if (cat) items = items.filter(i => (i.rs_category || '').includes(cat));
      if (filter) items = items.filter(i =>
        (i.stock_code || '').toLowerCase().includes(filter) ||
        (i.stock_name || '').toLowerCase().includes(filter)
      );

      // 排序
      const col = sortCol || 'rps_20';
      const dir = sortDir || 'desc';
      items.sort((a, b) => {
        let va = (a[col] != null ? a[col] : -Infinity);
        let vb = (b[col] != null ? b[col] : -Infinity);
        if (typeof va === 'string') { va = va.toLowerCase(); vb = (vb||'').toLowerCase(); return dir === 'asc' ? va.localeCompare(vb) : vb.localeCompare(va); }
        return dir === 'asc' ? (va - vb) : (vb - va);
      });

      if (items.length === 0) {
        document.getElementById('table-wrap').innerHTML = '<div class="loading">无匹配结果</div>';
        return;
      }

      let html = '<table class="obs-table"><thead><tr>';
      html += `<th onclick="thClick('stock_code')">代码<span class="sort-arrow">${sortArrow('stock_code')}</span></th>`;
      html += `<th onclick="thClick('stock_name')">名称<span class="sort-arrow">${sortArrow('stock_name')}</span></th>`;
      html += `<th onclick="thClick('industry_name')">行业<span class="sort-arrow">${sortArrow('industry_name')}</span></th>`;
      html += `<th>RS分类</th>`;
      html += `<th onclick="thClick('rps_20')">RPS20<span class="sort-arrow">${sortArrow('rps_20')}</span></th>`;
      html += `<th onclick="thClick('rps_250')">RPS250<span class="sort-arrow">${sortArrow('rps_250')}</span></th>`;
      html += `<th onclick="thClick('canslim_total')">CANSLIM<span class="sort-arrow">${sortArrow('canslim_total')}</span></th>`;
      html += `<th onclick="thClick('roe')">ROE<span class="sort-arrow">${sortArrow('roe')}</span></th>`;
      html += `<th onclick="thClick('revenue_yoy')">营收增速<span class="sort-arrow">${sortArrow('revenue_yoy')}</span></th>`;
      html += `<th>信号</th>`;
      html += `<th onclick="thClick('composite_score')">综合<span class="sort-arrow">${sortArrow('composite_score')}</span></th>`;
      html += `<th>操作</th>`;
      html += '</tr></thead><tbody>';

      for (const item of items) {
        const cats = (item.rs_category || '').split(' / ');
        const catTags = cats.map(c => {
          let cls = 'tag-steady';
          if (c === '龙头') cls = 'tag-leader';
          else if (c === '加速') cls = 'tag-burst';
          else if (c === '双强') cls = 'tag-double';
          else if (c === '短爆') cls = 'tag-short';
          else if (c === '稳健') cls = 'tag-steady';
          return `<span class="tag ${cls}">${c.trim()}</span>`;
        }).join(' ');

        html += '<tr>';
        html += `<td><a href="review.html?code=${item.stock_code}">${item.stock_code}</a></td>`;
        html += `<td>${item.stock_name || ''}</td>`;
        html += `<td>${item.industry_name || ''}</td>`;
        html += `<td>${catTags}</td>`;
        html += `<td>${(item.rps_20 || 0).toFixed(0)}</td>`;
        html += `<td>${(item.rps_250 || 0).toFixed(0)}</td>`;
        html += `<td>${item.canslim_total != null ? item.canslim_total.toFixed(0) : '-'}</td>`;
        html += `<td>${item.roe != null ? item.roe.toFixed(1) + '%' : '-'}</td>`;
        html += `<td>${item.revenue_yoy != null ? item.revenue_yoy.toFixed(1) + '%' : '-'}</td>`;
        html += `<td>${formatSignals(item)}</td>`;
        html += `<td><b>${item.composite_score != null ? item.composite_score.toFixed(0) : '-'}</b></td>`;
        html += `<td><button class="btn-run" onclick="addToWatchlist('${item.stock_code}','${item.stock_name}')" style="font-size:0.55rem;padding:2px 8px;">+自选</button></td>`;
        html += '</tr>';
      }
      html += '</tbody></table>';
      document.getElementById('table-wrap').innerHTML = html;
    }

    async function addToWatchlist(code, name) {
      try {
        const resp = await fetch('/api/discipline/watchlist', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ stock_code: code, stock_name: name })
        });
        const data = await resp.json();
        if (data.added) {
          alert('已加入自选池');
        } else {
          alert(data.error || '操作失败');
        }
      } catch (e) {
        alert('请求失败: ' + e.message);
      }
    }

    load();
  </script>
</body>
</html>
